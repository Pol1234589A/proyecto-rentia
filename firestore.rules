rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD Y AUXILIARES ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper para obtener datos del usuario de forma segura
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si es STAFF y si su cuenta está ACTIVA
    // Usamos .get() para evitar crashes si el campo no existe
    function isStaff() {
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().get('role', '') == 'staff'
        && getUserData().get('active', false) == true;
    }

    function isValidAmount() {
      return request.resource.data.amount is number;
    }
    
    function hasMandatoryFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // --- REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow write: if isStaff();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff() 
        && request.resource.data.financials.purchasePrice is number;
    }
    
    match /accounting/{transactionId} {
      allow read: if isStaff();
      allow write: if isStaff() 
        && isValidAmount()
        && hasMandatoryFields(['date', 'concept', 'type']);
    }
    
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Contratos: Lectura para Staff o las partes involucradas (Dueño/Inquilino)
    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && (
             resource.data.get('ownerId', '') == request.auth.uid || 
             resource.data.get('tenantId', '') == request.auth.uid
           ));
      allow write: if isStaff();
    }

    match /tasks/{taskId} {
      allow read, write: if isStaff();
    }

    match /social_inbox/{msgId} {
      allow read: if isStaff();
      allow write: if true; 
    }
    
    match /supply_records/{recordId} {
        allow read: if isAuthenticated();
        allow write: if isStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}