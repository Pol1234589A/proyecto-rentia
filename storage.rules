
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuth() {
      return request.auth != null;
    }

    // 1. FIRMAS RGPD
    match /signatures/{userId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId;
    }

    // 2. DOCUMENTOS Y FACTURAS PROPIEDADES
    match /documents/{propertyId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /invoices/{propertyId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // 3. FACTURAS DE TRABAJADORES
    match /worker_invoices/{userId}/{allPaths=**} {
      allow read, write: if isAuth();
    }

    // 4. IMÁGENES PÚBLICAS (Oportunidades, Propiedades, Habitaciones)
    match /opportunities/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth(); 
    }
    
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    match /rooms/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // 5. SOLICITUDES COLABORADORES (Subida Pública para formulario web)
    // Permite create a cualquiera (para el form), read solo autenticados (staff revisando)
    match /requests/{requestId}/{allPaths=**} {
      allow create: if true;
      allow read: if isAuth();
    }

    // 6. FEEDS XML (Público para sincronización con portales)
    match /feeds/{fileName} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Regla por defecto
    match /{allPaths=**} {
      allow read, write: if isAuth(); 
    }
  }
}
