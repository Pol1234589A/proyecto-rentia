
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. FUNCIONES DE AYUDA (HELPERS) ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      let userData = getUserData();
      return isAuthenticated() && 
             userData.role == role && 
             (!("active" in userData) || userData.active == true);
    }

    // --- 2. DEFINICIÓN DE PERFILES ---

    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    function isWorker() {
      return hasRole('worker');
    }

    function isTeam() {
      return isStaff() || isWorker();
    }

    function isOwner() { return hasRole('owner'); }
    function isTenant() { return hasRole('tenant'); }

    // --- 3. LÓGICA DE PROPIEDAD (SEGURIDAD DE DATOS) ---
    
    function propertyBelongsToOwner(propertyId) {
       return get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // --- 4. REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      allow read: if true; 
      allow create: if isStaff();       
      
      // Permitir que el usuario edite su propio perfil (ej. firmar GDPR)
      // Bloqueamos cambio de rol y estado activo para evitar escalada de privilegios
      allow update: if isStaff() || (
        isSelf(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().has('role')) &&
        (!request.resource.data.diff(resource.data).affectedKeys().has('active'))
      );
      
      allow delete: if isStaff();
    }

    match /properties/{propertyId} {
      allow read: if true; 
      allow write: if isTeam() || (isOwner() && resource.data.ownerId == request.auth.uid); 
    }

    match /property_documents/{docId} {
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow create: if isStaff() || (isOwner() && propertyBelongsToOwner(request.resource.data.propertyId));
      allow update, delete: if isStaff();
    }

    match /supply_invoices/{invoiceId} {
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow create: if isStaff() || (isOwner() && propertyBelongsToOwner(request.resource.data.propertyId));
      allow update, delete: if isStaff();
    }

    match /opportunities/{opportunityId} {
      allow read: if true; 
      allow write: if isStaff();
    }
    
    match /opportunity_requests/{requestId} {
      allow create: if true; 
      allow read, update, delete: if isStaff();
    }

    match /buyer_requests/{requestId} {
      allow read: if true; 
      allow write: if isStaff();
    }

    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.tenantId == request.auth.uid);
      allow write: if isStaff();
    }

    match /tasks/{taskId} {
      allow read: if isTeam() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow write: if isTeam();
    }
    match /task_boards/{boardId} {
      allow read, write: if isTeam();
    }

    match /adjustments/{adjustmentId} {
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow write: if isStaff();
    }

    match /social_inbox/{msgId} {
      allow read, write: if isTeam();
    }

    match /accounting/{transactionId} {
      allow read, write: if isStaff();
    }

    match /supply_records/{recordId} {
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow write: if isStaff();
    }

    match /candidate_pipeline/{candidateId} {
      allow read: if isTeam() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      // VALIDACIÓN: Es obligatorio que exista el campo 'submittedBy' al crear
      allow create: if isTeam() && (request.resource.data.submittedBy != null);
      allow update: if isTeam();
      allow delete: if isStaff();
    }

    match /room_visits/{visitId} {
      allow read: if isTeam() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow create: if isTeam();
      allow update, delete: if isStaff();
    }

    match /internal_news/{newsId} {
      allow read: if isTeam();
      allow write: if isStaff();
    }

    match /sales_tracker/{activityId} {
      allow read, write: if isStaff();
    }

    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff(); 
    }

    match /web_messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
