
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuth() {
      return request.auth != null;
    }

    // 1. FIRMAS RGPD
    match /signatures/{userId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId;
    }

    // 2. DOCUMENTOS Y FACTURAS PROPIEDADES (Para Owner Dashboard)
    // Se permite escritura a autenticados para que los propietarios puedan subir sus archivos.
    // La seguridad de quién ve qué se maneja principalmente en Firestore (property_documents).
    match /documents/{propertyId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /invoices/{propertyId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Contratos PDF subidos por Admin/Staff
    match /contracts/{propertyId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // 3. FACTURAS DE TRABAJADORES
    match /worker_invoices/{userId}/{allPaths=**} {
      allow read, write: if isAuth();
    }

    // 4. IMÁGENES PÚBLICAS (Oportunidades, Propiedades, Habitaciones)
    match /opportunities/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth(); 
    }
    
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    match /rooms/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // 5. SOLICITUDES COLABORADORES (Subida Pública para formulario web)
    // Se permite 'create' a todo el mundo para que el formulario público pueda subir fotos.
    // Se permite 'read' a todo el mundo para poder mostrar la previsualización tras la subida (getDownloadURL).
    match /requests/{requestId}/{allPaths=**} {
      allow create: if true;
      allow read: if true;
    }

    // 6. FEEDS XML (Público para sincronización con portales)
    match /feeds/{fileName} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Regla por defecto para el resto
    match /{allPaths=**} {
      allow read, write: if isAuth(); 
    }
  }
}
