
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Obtener datos del usuario actual desde Firestore para verificar roles
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isWorker() {
      return hasRole('worker');
    }

    // Verificar si la propiedad objetivo pertenece al usuario actual
    function propertyBelongsToOwner(propertyId) {
       return get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // --- REGLAS POR COLECCIÓN ---

    // USERS
    match /users/{userId} {
      allow read: if true;
      // Allow creation if staff (admin creating owner) or self (signup flow triggers)
      allow create: if isStaff() || isSelf(userId); 
      allow update: if isStaff() || isSelf(userId); 
      allow delete: if isStaff();
    }

    // PROPERTIES
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff() || isWorker(); 
    }

    // DOCUMENTOS DE PROPIEDAD (Gestión Propietarios)
    match /property_documents/{docId} {
      // Lectura: Staff o Propietario dueño de la propiedad
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      // Creación: Staff o Propietario dueño de la propiedad (en el payload)
      allow create: if isStaff() || (isOwner() && propertyBelongsToOwner(request.resource.data.propertyId));
      // Edición/Borrado: Solo Staff
      allow update, delete: if isStaff();
    }

    // FACTURAS SUMINISTROS (Gestión Propietarios)
    match /supply_invoices/{invoiceId} {
      // Lectura: Staff o Propietario dueño de la propiedad
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      // Creación: Staff o Propietario dueño de la propiedad
      allow create: if isStaff() || (isOwner() && propertyBelongsToOwner(request.resource.data.propertyId));
      // Edición/Borrado: Solo Staff (para aprobar/rechazar)
      allow update, delete: if isStaff();
    }
    
    // COLECCIÓN: TRASPASOS PENDIENTES
    match /pending_transfers/{transferId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // REGISTROS DE CÁLCULO DE SUMINISTROS (Calculadora Staff)
    match /supply_records/{recordId} {
      allow read, write: if isStaff();
    }

    // AJUSTES ECONÓMICOS PROPIETARIOS
    match /adjustments/{adjustmentId} {
      allow read: if isStaff() || (isOwner() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaff();
    }

    // CONTABILIDAD GENERAL
    match /accounting/{docId} {
      allow read, write: if isStaff();
    }

    // OPORTUNIDADES (Cartera de Inversión)
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // CONTRATOS
    match /contracts/{contractId} {
      allow read: if isStaff() || isWorker() || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow write: if isStaff();
    }

    // TAREAS
    match /tasks/{taskId} {
      allow read: if isStaff() || isWorker();
      allow write: if isStaff() || isWorker();
    }

    // TABLEROS DE TAREAS
    match /task_boards/{boardId} {
      allow read: if isStaff() || isWorker();
      allow write: if isStaff();
    }

    // PIPELINE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      allow read: if isStaff() || isWorker() || (isOwner() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaff() || isWorker();
    }

    // REGISTRO DE VISITAS
    match /room_visits/{visitId} {
      allow read: if isStaff() || isWorker();
      allow write: if isStaff() || isWorker();
    }

    // NOTICIAS INTERNAS
    match /internal_news/{newsId} {
      allow read: if isStaff() || isWorker();
      allow write: if isStaff();
    }

    // FACTURAS DE TRABAJADORES
    match /worker_invoices/{invoiceId} {
      allow read: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if isStaff() || (isWorker() && request.resource.data.workerId == request.auth.uid);
      allow update: if isStaff(); 
      allow delete: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
    }

    // DEMANDAS DE COMPRA (Broker Requests)
    match /buyer_requests/{requestId} {
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if isStaff();
    }

    // SOLICITUDES DE COLABORACIÓN (Opportunity Requests)
    match /opportunity_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // SALES TRACKER (CRM Actividad)
    match /sales_tracker/{trackId} {
      allow read, write: if isStaff();
    }

    // BLACKLIST / INCIDENCIAS
    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff();
    }

    // Fallback: cerrar todo lo demás por seguridad
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
