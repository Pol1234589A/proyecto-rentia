
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Ayuda ---

    // 1. Verifica si el usuario ha iniciado sesión
    function isAuthenticated() {
      return request.auth != null;
    }

    // 2. Verifica si el usuario es dueño del documento (útil para perfiles)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 3. Verifica si es STAFF leyendo el campo 'role' de su documento de usuario en Firestore
    // Esto conecta tu autenticación con el dato que has puesto en la base de datos (role: "staff")
    function isStaff() {
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // --- Reglas por Colección ---

    // 1. Usuarios: Cada uno lee lo suyo, Staff lee/escribe todo
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow write: if isStaff();
    }

    // 2. Propiedades: Público lee, Solo Staff edita
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 3. Oportunidades: Público lee, Solo Staff edita
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // 4. Contabilidad: Estrictamente privado para Staff
    match /accounting/{transactionId} {
      allow read, write: if isStaff();
    }
    
    // 5. Encargos de Compra (CRM):
    // - Lectura pública (para que se vean en la sección /colaboradores de la web)
    // - Escritura solo Staff (desde el CRM)
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 6. Bloqueo por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
