
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD Y AUXILIARES ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper para verificar existencia antes de leer datos
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper para obtener datos del usuario de forma segura
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si es STAFF (Staff, Admin, Owner)
    function isStaff() {
      return isAuthenticated() 
        && userExists()
        && (getUserData().role == 'staff' || getUserData().role == 'admin' || getUserData().role == 'owner');
    }

    // Verifica si es WORKER
    function isWorker() {
      return isAuthenticated() 
        && userExists()
        && getUserData().role == 'worker';
    }

    // Helper combinado
    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    function isValidAmount() {
      return request.resource.data.amount is number;
    }
    
    function hasMandatoryFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // --- REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaffOrWorker();
      allow write: if isStaff();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /accounting/{transactionId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }
    
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && (
             resource.data.get('ownerId', '') == request.auth.uid || 
             resource.data.get('tenantId', '') == request.auth.uid
           ));
      allow write: if isStaff();
    }

    match /tasks/{taskId} {
      allow read: if isStaffOrWorker();
      allow create: if isStaffOrWorker();
      allow update: if isStaffOrWorker();
      allow delete: if isStaff(); 
    }

    match /task_boards/{boardId} {
      allow read: if isStaffOrWorker();
      allow write: if isStaffOrWorker();
    }

    match /social_inbox/{msgId} {
      allow read: if isStaff();
      allow write: if true; 
    }
    
    match /supply_records/{recordId} {
        allow read: if isAuthenticated();
        allow create: if isStaff();
        allow update: if isStaff(); // Permite modificar estado (Pendiente/Pagado)
        allow delete: if isStaff(); // Permite borrar facturas erróneas
    }
    
    // PERMISOS AMPLIADOS: Workers también pueden actualizar estado (Aprobar/Rechazar)
    match /candidate_pipeline/{candidateId} {
        allow create: if isStaffOrWorker();
        allow read: if isStaffOrWorker();
        allow update: if isStaffOrWorker();
        allow delete: if isStaff();
    }

    match /room_visits/{visitId} {
        // Workers pueden registrar visitas. Staff puede ver y gestionar todo el historial.
        allow create: if isStaffOrWorker();
        allow read, update, delete: if isStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
