rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- FUNCIONES DE AYUDA ---

    function getRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return request.auth != null && (getRole() == 'staff' || getRole() == 'admin' || getRole() == 'agency');
    }

    function isTeam() {
      return request.auth != null && (getRole() == 'staff' || getRole() == 'admin' || getRole() == 'agency' || getRole() == 'worker');
    }

    // --- REGLAS POR CARPETA ---

    // Oportunidades e Inmuebles: Público lectura (para mostrar en web), Staff/Team escritura
    match /opportunities/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if isTeam(); 
    }
    
    match /rooms/{allPaths=**} {
      allow read: if true;
      allow write: if isTeam(); 
    }

    // Feeds XML: Público lectura, Staff escritura
    match /feeds/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Documentación Privada (Contratos, DNIs): Solo accesible por el dueño/inquilino propio o staff
    match /contracts/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isStaff());
      allow write: if isStaff();
    }
    
    // SOLICITUDES PUBLICAS DE COLABORADORES (FORMULARIO WEB)
    // Permite subida pública (o autenticada anónima) para el formulario de captación.
    // Solo Staff puede leer/descargar estos archivos. Protege planos, notas simples, etc.
    match /requests/{requestId}/{allPaths=**} {
      allow read: if isStaff();
      allow write: if true; 
    }

    // Regla por defecto: Bloqueo total
    match /{allPaths=**} {
      allow read, write: if isStaff();
    }
  }
}