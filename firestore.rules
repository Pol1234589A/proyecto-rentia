
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA (HELPERS) ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verificación de Rol Robusta
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Roles Jerárquicos
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isWorker() {
      return hasRole('worker');
    }

    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    // --- REGLAS POR COLECCIÓN ---

    // 1. USUARIOS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isStaff();
    }

    // 2. PROPIEDADES
    match /properties/{propertyId} {
      allow read: if true; 
      allow update: if isStaffOrWorker() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow create, delete: if isStaffOrWorker();
    }

    // 3. DOCUMENTOS
    match /property_documents/{docId} {
      allow read: if isStaff() || isOwner() || isWorker();
      allow create: if isAuthenticated();
      allow update: if isStaff();
      allow delete: if isStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 4. FACTURAS SUMINISTROS
    match /supply_invoices/{invoiceId} {
      allow read: if isStaff() || isOwner() || isWorker();
      allow create: if isAuthenticated(); 
      allow update, delete: if isStaff();
    }
    
    // 5. CÁLCULOS SUMINISTROS
    match /supply_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 6. AJUSTES ECONÓMICOS
    match /adjustments/{adjustmentId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaff();
    }

    // 7. CONTABILIDAD
    match /accounting/{docId} {
      allow read, write: if isStaff();
    }

    // 8. OPORTUNIDADES
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // 9. CONTRATOS
    match /contracts/{contractId} {
      allow read: if isStaffOrWorker() || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow write: if isStaff();
    }

    // 10. TAREAS
    match /tasks/{taskId} {
      allow read, write: if isStaffOrWorker();
    }
    match /task_boards/{boardId} {
      allow read, write: if isStaffOrWorker();
    }

    // 11. PIPELINE
    match /candidate_pipeline/{candidateId} {
      allow read: if isStaffOrWorker() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaffOrWorker();
    }

    // 12. VISITAS
    match /room_visits/{visitId} {
      allow read, write: if isStaffOrWorker();
    }

    // 13. NOTICIAS
    match /internal_news/{newsId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 14. FACTURAS TRABAJADORES
    match /worker_invoices/{invoiceId} {
      allow read: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if isStaff() || (isWorker() && request.resource.data.workerId == request.auth.uid);
      allow update: if isStaff(); 
      allow delete: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
    }

    // 15. FORMULARIOS WEB
    match /buyer_requests/{requestId} {
      allow read: if true; 
      allow create: if true;
      allow update, delete: if isStaff();
    }
    match /opportunity_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }
    match /pending_transfers/{transferId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // 16. TRACKING Y SEGURIDAD
    match /sales_tracker/{trackId} {
      allow read, write: if isStaff();
    }
    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff();
    }

    // 17. FACTURAS DE AGENCIA (LIQUIDACIONES)
    match /agency_invoices/{invoiceId} {
        // Staff puede hacer todo
        allow read, write: if isStaff();
        // Propietario solo puede leer las suyas
        allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Regla por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
