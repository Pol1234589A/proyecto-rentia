rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. FUNCIONES DE AYUDA (HELPERS) ---

    // Verifica autenticación básica
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si el usuario actúa sobre su propio documento
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Obtiene los datos del usuario actual desde la DB
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica rol específico
    function hasRole(role) {
      let userData = getUserData();
      return isAuthenticated() && 
             userData.role == role && 
             (!("active" in userData) || userData.active == true);
    }

    // --- 2. DEFINICIÓN DE PERFILES ---

    // STAFF: Gerencia, Admin, Agencia (Acceso total o alto nivel)
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    // WORKER: Trabajadores de campo / Comerciales
    function isWorker() {
      return hasRole('worker');
    }

    // TEAM: Equipo interno completo (Staff + Workers)
    function isTeam() {
      return isStaff() || isWorker();
    }

    // ROLES EXTERNOS
    function isOwner() { return hasRole('owner'); }
    function isTenant() { return hasRole('tenant'); }

    // --- 3. LÓGICA DE PROPIEDAD (SEGURIDAD DE DATOS) ---
    
    // Verifica si la propiedad referenciada pertenece al usuario actual
    function propertyBelongsToOwner(propertyId) {
       return get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // --- 4. REGLAS POR COLECCIÓN ---

    // USUARIOS
    // Seguridad Crítica: Un usuario no puede modificar su propio 'role', 'active' o 'createdBy'.
    match /users/{userId} {
      allow read: if isAuthenticated(); // Necesario para AuthContext y verificar roles
      allow create: if isStaff();       // Solo Staff crea usuarios nuevos
      allow update: if isStaff() || (isSelf(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'active', 'createdBy'])); 
      allow delete: if isStaff();
    }

    // PROPIEDADES (INVENTARIO)
    match /properties/{propertyId} {
      allow read: if true; // Catálogo público
      allow write: if isStaff();
    }

    // OPORTUNIDADES (INVERSIÓN)
    match /opportunities/{opportunityId} {
      allow read: if true; // Público
      allow write: if isStaff();
    }

    // ENCARGOS DE COMPRA (DEMANDAS)
    match /buyer_requests/{requestId} {
      allow read: if true; // Público en sección Brokers
      allow write: if isStaff();
    }

    // CONTRATOS
    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.tenantId == request.auth.uid);
      allow write: if isStaff();
    }

    // TAREAS Y TABLEROS (GESTIÓN INTERNA)
    match /tasks/{taskId} {
      allow read, write: if isTeam();
    }
    match /task_boards/{boardId} {
      allow read, write: if isTeam();
    }

    // MENSAJERÍA / CRM
    match /social_inbox/{msgId} {
      allow read, write: if isTeam();
    }

    // CONTABILIDAD (SENSIBLE)
    match /accounting/{transactionId} {
      allow read, write: if isStaff(); // Solo Staff/Admin
    }

    // REGISTRO DE SUMINISTROS
    match /supply_records/{recordId} {
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow write: if isStaff();
    }

    // PIPELINE DE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      allow read: if isTeam();
      allow create: if isTeam();
      allow update: if isTeam();
      allow delete: if isStaff();
    }

    // REGISTRO DE VISITAS
    match /room_visits/{visitId} {
      allow read: if isTeam() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow create: if isTeam();
      allow update, delete: if isStaff();
    }

    // NOTICIAS INTERNAS
    match /internal_news/{newsId} {
      allow read: if isTeam();
      allow write: if isStaff();
    }

    // TRACKING DE VENTAS
    match /sales_tracker/{activityId} {
      allow read, write: if isStaff();
    }

    // BLACKLIST / INCIDENCIAS (MUY SENSIBLE)
    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff(); // Solo Staff
    }

    // MENSAJES WEB (CONTACTO)
    match /web_messages/{msgId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // Bloqueo por defecto para cualquier otra colección no definida
    match /{document=**} {
      allow read, write: if false;
    }
  }
}