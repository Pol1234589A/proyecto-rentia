
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. FUNCIONES DE AYUDA (HELPERS) ---

    // Verifica si el usuario está logueado en Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si el usuario es el dueño del propio documento (para editar perfil)
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Obtiene los datos del usuario actual desde la colección 'users' para verificar rol
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si el usuario tiene un rol específico y la cuenta está activa
    function hasRole(role) {
      let userData = getUserData();
      return isAuthenticated() && 
             userData.role == role && 
             (!("active" in userData) || userData.active == true);
    }

    // --- 2. DEFINICIÓN DE ROLES ---

    // STAFF: Acceso administrativo total (Gerencia, Admin, Oficina)
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    // WORKER: Trabajadores de campo (Comerciales, Mantenimiento)
    function isWorker() {
      return hasRole('worker');
    }

    // OWNER: Propietarios de inmuebles
    function isOwner() {
      return hasRole('owner');
    }

    // TEAM: Equipo operativo interno (Staff + Workers)
    function isTeam() {
      return isStaff() || isWorker();
    }

    // --- 3. REGLAS POR COLECCIÓN ---

    // USUARIOS: Staff gestiona todo. Usuarios se leen a sí mismos.
    // Lectura abierta a autenticados para que los selectores de "Asignado a" funcionen.
    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow create: if isStaff(); 
      allow update: if isStaff() || isSelf(userId); 
      allow delete: if isStaff();
    }

    // PROPIEDADES: Público lectura (Web), Staff escritura (Inventario)
    match /properties/{propertyId} {
      allow read: if true; 
      allow write: if isStaff(); 
    }

    // OPORTUNIDADES (INVERSIÓN): Público lectura, Staff escritura
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ENCARGOS DE COMPRA (BROKERS): Público lectura, Staff escritura
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // CONTRATOS: Staff total. Owners e Inquilinos solo ven los suyos.
    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.tenantId == request.auth.uid);
      allow write: if isStaff();
    }

    // TAREAS: Equipo operativo (Staff + Workers)
    match /tasks/{taskId} {
      allow read, write: if isTeam();
    }
    match /task_boards/{boardId} {
      allow read, write: if isTeam();
    }

    // MENSAJERÍA SOCIAL (CRM): Equipo operativo
    match /social_inbox/{msgId} {
      allow read, write: if isTeam();
    }

    // CONTABILIDAD: Estrictamente Staff (Datos financieros sensibles)
    match /accounting/{transactionId} {
      allow read, write: if isStaff();
    }

    // SUMINISTROS: Staff gestiona. 
    match /supply_records/{recordId} {
      allow read: if isStaff(); 
      allow write: if isStaff();
    }

    // CANDIDATOS (PIPELINE): Workers crean/mueven, Staff gestiona/borra
    match /candidate_pipeline/{candidateId} {
      allow read: if isTeam();
      allow create: if isTeam(); 
      allow update: if isTeam(); 
      allow delete: if isStaff();
    }

    // VISITAS (LOG): Workers crean, Owners leen (Dashboard), Staff gestiona
    match /room_visits/{visitId} {
      allow read: if isTeam() || isOwner(); 
      allow create: if isTeam();
      allow update: if isStaff(); 
      allow delete: if isStaff(); 
    }

    // NOTICIAS INTERNAS: Staff publica, Equipo lee
    match /internal_news/{newsId} {
      allow read: if isTeam();
      allow write: if isStaff();
    }

    // TRACKING VENTAS: Staff
    match /sales_tracker/{activityId} {
      allow read, write: if isStaff();
    }

    // REGISTRO DE INCIDENCIAS/RIESGOS (Antigua Blacklist): Estrictamente Staff (RGPD)
    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff();
    }

    // MENSAJES WEB (Formulario contacto): Cualquiera crea, solo Staff lee
    match /web_messages/{msgId} {
      allow create: if true; 
      allow read, update, delete: if isStaff();
    }

    // Bloqueo por defecto para cualquier otra colección no definida (Seguridad por defecto)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
