
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA (HELPERS) ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // Roles Jerárquicos
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isWorker() {
      return hasRole('worker');
    }

    // Helper combinado para operaciones de gestión diaria
    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    // --- REGLAS POR COLECCIÓN ---

    // 1. USUARIOS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isStaff();
    }

    // 2. PROPIEDADES (Catálogo y Configuración)
    match /properties/{propertyId} {
      // Lectura pública para la web
      allow read: if true; 
      
      // Permitir edición si es Staff/Worker O si el usuario es el dueño legítimo del documento
      allow update: if isStaffOrWorker() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      
      // Permitir crear (materializar propiedad estática) si el usuario se asigna como owner legítimo
      allow create: if isStaffOrWorker() || (isAuthenticated() && request.resource.data.ownerId == request.auth.uid);
      allow delete: if isStaffOrWorker();
    }

    // 3. DOCUMENTOS DE PROPIEDAD
    match /property_documents/{docId} {
      allow read: if isStaff() || isOwner() || isWorker();
      allow create: if isAuthenticated();
      allow update: if isStaff();
      allow delete: if isStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 4. FACTURAS DE SUMINISTROS
    match /supply_invoices/{invoiceId} {
      allow read: if isStaff() || isOwner() || isWorker();
      allow create: if isAuthenticated(); 
      allow update, delete: if isStaff();
    }
    
    // 5. CÁLCULOS DE SUMINISTROS
    match /supply_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 6. AJUSTES ECONÓMICOS
    match /adjustments/{adjustmentId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaff();
    }

    // 7. CONTABILIDAD
    match /accounting/{docId} {
      allow read, write: if isStaff();
    }

    // 8. OPORTUNIDADES (Venta) - Gestión completa desde CRM
    match /opportunities/{opportunityId} {
      allow read: if true; // Web pública
      allow write: if isStaff(); // CRM Admin (Crear, Editar, Borrar)
    }
    
    // 9. CONTRATOS
    match /contracts/{contractId} {
      allow read: if isStaffOrWorker() || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow write: if isStaff();
    }

    // 10. TAREAS
    match /tasks/{taskId} {
      allow read, write: if isStaffOrWorker();
    }

    match /task_boards/{boardId} {
      allow read, write: if isStaffOrWorker();
    }

    // 11. PIPELINE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      allow read: if isStaffOrWorker() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaffOrWorker();
    }

    // 12. VISITAS
    match /room_visits/{visitId} {
      allow read, write: if isStaffOrWorker();
    }

    // 13. NOTICIAS INTERNAS
    match /internal_news/{newsId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 14. FACTURAS TRABAJADORES
    match /worker_invoices/{invoiceId} {
      allow read: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if isStaff() || (isWorker() && request.resource.data.workerId == request.auth.uid);
      allow update: if isStaff(); 
      allow delete: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
    }

    // 15. WEB FORMS (CRM de Compras y Captación)
    match /buyer_requests/{requestId} {
      allow read: if true; // Necesario para listado público en BrokerView
      allow create: if true; // Formulario público
      allow update, delete: if isStaff(); // Gestión CRM
    }

    match /opportunity_requests/{requestId} {
      allow create: if true; // Formulario público
      allow read, update, delete: if isStaff(); // Gestión CRM
    }
    
    match /pending_transfers/{transferId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // 16. LEADS DE OPORTUNIDADES (Formulario de contacto individual)
    match /opportunity_leads/{leadId} {
        allow create: if true; // Público
        allow read, update, delete: if isStaff(); // Solo CRM
    }

    // 17. TRACKING Y SEGURIDAD
    match /sales_tracker/{trackId} {
      allow read, write: if isStaff();
    }

    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff();
    }

    // 18. FACTURAS DE AGENCIA (LIQUIDACIONES)
    match /agency_invoices/{invoiceId} {
        allow read: if isStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
        allow write: if isStaff();
    }

    // Regla por defecto de seguridad
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
