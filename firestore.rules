
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    // Verifica si el usuario está autenticado en Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si el usuario accede a su propio documento (por UID)
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper seguro para obtener el documento del usuario
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Verifica el rol y si la cuenta está activa de forma segura
    function hasRole(role) {
      let userDoc = getUserDoc();
      return isAuthenticated() && 
             userDoc != null &&
             userDoc.data.role == role && 
             (!("active" in userDoc.data) || userDoc.data.active == true);
    }

    // STAFF: Empleados internos con permisos de gestión (Staff y Admin)
    // Se ha eliminado 'owner' de este grupo para evitar que clientes externos editen datos sensibles.
    function isStaff() {
      return hasRole('staff') || hasRole('admin');
    }

    // WORKER: Trabajadores de campo (Comerciales, Mantenimiento)
    function isWorker() {
      return hasRole('worker');
    }

    // STAFF O WORKER: Para funciones operativas compartidas
    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    // --- REGLAS POR COLECCIÓN ---

    // 1. USUARIOS (USERS)
    match /users/{userId} {
      allow read: if isSelf(userId) || isStaffOrWorker();
      allow create: if isStaff(); // Solo staff crea usuarios desde el panel
      allow update: if isStaff() || isSelf(userId);
      allow delete: if isStaff();
    }

    // 2. PROPIEDADES (PROPERTIES)
    // Lectura pública para la web. Escritura restringida a Staff.
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 3. OPORTUNIDADES (OPPORTUNITIES)
    // Lectura pública para la landing de inversión. Escritura restringida.
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 4. ENCARGOS DE COMPRA (BUYER_REQUESTS)
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 5. CONTRATOS (CONTRACTS)
    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.tenantId == request.auth.uid);
      allow write: if isStaff();
    }

    // 6. TAREAS Y TABLEROS (TASKS & BOARDS)
    // Lectura y escritura para equipo interno (Staff y Workers)
    match /tasks/{taskId} {
      allow read, write: if isStaffOrWorker();
    }
    match /task_boards/{boardId} {
      allow read, write: if isStaffOrWorker();
    }

    // 7. BUZÓN SOCIAL (SOCIAL_INBOX)
    match /social_inbox/{msgId} {
      allow read: if isStaff();
      allow create: if true; // Permitir entrada anónima (Formularios/Webhooks)
      allow update, delete: if isStaff();
    }

    // 8. CONTABILIDAD (ACCOUNTING)
    match /accounting/{transactionId} {
      allow read, write: if isStaff();
    }

    // 9. SUMINISTROS (SUPPLY_RECORDS)
    match /supply_records/{recordId} {
      // Acceso restringido a Staff para gestión. 
      // Los inquilinos verán su parte a través de la UI que filtra datos o documentos generados.
      allow read, write: if isStaff();
    }

    // 10. PIPELINE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      allow read: if isStaffOrWorker();
      allow create: if isStaffOrWorker();
      allow update: if isStaff(); // Solo Staff aprueba/rechaza definitivamente
      allow delete: if isStaff();
    }

    // 11. REGISTRO DE VISITAS (ROOM_VISITS)
    match /room_visits/{visitId} {
      allow read: if isStaffOrWorker();
      allow create: if isStaffOrWorker();
      allow update, delete: if isStaff();
    }

    // 12. NOTICIAS INTERNAS (INTERNAL_NEWS)
    // Visible para todos los trabajadores, editable solo por Staff
    match /internal_news/{newsId} {
      allow read: if isStaffOrWorker();
      allow write: if isStaff();
    }

    // Bloqueo por defecto para cualquier otra colección no definida
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
