
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD Y AUXILIARES ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper para obtener datos del usuario de forma segura
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si es STAFF (Staff, Admin, Owner)
    function isStaff() {
      let role = getUserData().get('role', '');
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (role == 'staff' || role == 'admin' || role == 'owner')
        && getUserData().get('active', false) == true;
    }

    // Verifica si es WORKER (Nuevo Rol para Ayoub)
    function isWorker() {
      let role = getUserData().get('role', '');
      return isAuthenticated() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && role == 'worker'
        && getUserData().get('active', false) == true;
    }

    // Helper combinado: Staff O Trabajador
    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    function isValidAmount() {
      return request.resource.data.amount is number;
    }
    
    function hasMandatoryFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // --- REGLAS POR COLECCIÓN ---

    match /users/{userId} {
      // El Worker necesita leer su propio perfil para que la app determine su rol
      allow read: if isOwner(userId) || isStaffOrWorker();
      allow write: if isStaff();
    }

    match /properties/{propertyId} {
      allow read: if true; // Público para la web y Worker
      allow write: if isStaff();
    }

    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff() 
        && request.resource.data.financials.purchasePrice is number;
    }
    
    match /accounting/{transactionId} {
      allow read: if isStaff();
      allow write: if isStaff() 
        && isValidAmount()
        && hasMandatoryFields(['date', 'concept', 'type']);
    }
    
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Contratos: Lectura para Staff o las partes involucradas (Dueño/Inquilino)
    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && (
             resource.data.get('ownerId', '') == request.auth.uid || 
             resource.data.get('tenantId', '') == request.auth.uid
           ));
      allow write: if isStaff();
    }

    // TAREAS (Tasks) - ACTUALIZADO PARA WORKER
    match /tasks/{taskId} {
      // Lectura: Staff ve todo, Worker ve sus tareas y las del equipo
      allow read: if isStaffOrWorker();
      
      // Creación: Worker puede crear incidencias, Staff crea tareas
      allow create: if isStaffOrWorker();
      
      // Actualización: Worker actualiza estado, Staff todo
      allow update: if isStaffOrWorker();
      
      // Borrado: Solo Staff puede borrar tareas definitivamente
      allow delete: if isStaff(); 
    }

    match /task_boards/{boardId} {
      allow read: if isStaffOrWorker();
      allow write: if isStaff();
    }

    match /social_inbox/{msgId} {
      allow read: if isStaff();
      allow write: if true; 
    }
    
    match /supply_records/{recordId} {
        allow read: if isAuthenticated();
        allow write: if isStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
