
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. FUNCIONES DE AYUDA (HELPERS) ---

    // Verifica autenticación básica
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si el usuario actúa sobre su propio documento
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Obtiene los datos del usuario actual para verificar su rol
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica rol y estado activo
    function hasRole(role) {
      let userData = getUserData();
      return isAuthenticated() && 
             userData.role == role && 
             (!("active" in userData) || userData.active == true);
    }

    // --- 2. DEFINICIÓN DE PERFILES ---

    // STAFF: Gerencia, Admin, Agencia (Acceso total)
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    // WORKER: Trabajadores de campo / Comerciales
    function isWorker() {
      return hasRole('worker');
    }

    // TEAM: Equipo interno completo (Staff + Workers)
    function isTeam() {
      return isStaff() || isWorker();
    }

    // ROLES EXTERNOS
    function isOwner() { return hasRole('owner'); }
    function isTenant() { return hasRole('tenant'); }

    // --- 3. LÓGICA DE PROPIEDAD (SEGURIDAD DE DATOS) ---
    
    // Verifica si la propiedad referenciada en un documento pertenece al usuario actual (Propietario)
    function propertyBelongsToOwner(propertyId) {
       return get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // --- 4. REGLAS POR COLECCIÓN ---

    // USUARIOS
    match /users/{userId} {
      allow read: if isAuthenticated(); // Necesario para Selectores y AuthContext
      allow create: if isStaff();       // Solo Staff crea usuarios
      allow update: if isStaff() || isSelf(userId); // Staff edita a todos, Usuario se edita a sí mismo
      allow delete: if isStaff();
    }

    // PROPIEDADES (INVENTARIO)
    match /properties/{propertyId} {
      allow read: if true; // Catálogo público para la web
      allow write: if isStaff(); // Staff gestiona inventario y asigna propietarios
    }

    // OPORTUNIDADES (INVERSIÓN)
    match /opportunities/{opportunityId} {
      allow read: if true; // Público para captación de inversores
      allow write: if isStaff();
    }

    // ENCARGOS DE COMPRA (DEMANDAS)
    match /buyer_requests/{requestId} {
      allow read: if true; // Visible en área pública de Brokers
      allow write: if isStaff();
    }

    // CONTRATOS
    match /contracts/{contractId} {
      // Staff ve todo. Propietarios e Inquilinos solo ven SUS contratos.
      allow read: if isStaff() 
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.tenantId == request.auth.uid);
      allow write: if isStaff();
    }

    // TAREAS Y TABLEROS (GESTIÓN INTERNA)
    match /tasks/{taskId} {
      allow read, write: if isTeam(); // Todo el equipo colabora
    }
    match /task_boards/{boardId} {
      allow read, write: if isTeam();
    }

    // MENSAJERÍA / CRM
    match /social_inbox/{msgId} {
      allow read, write: if isTeam();
    }

    // CONTABILIDAD (SENSIBLE)
    match /accounting/{transactionId} {
      allow read, write: if isStaff(); // Solo administración
    }

    // REGISTRO DE SUMINISTROS
    match /supply_records/{recordId} {
      // Staff gestiona. Propietario ve SOLO las facturas de sus propiedades.
      allow read: if isStaff() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow write: if isStaff();
    }

    // PIPELINE DE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      allow read: if isTeam();
      allow create: if isTeam(); // Workers envían candidatos
      allow update: if isTeam(); // Workers mueven estados
      allow delete: if isStaff();
    }

    // REGISTRO DE VISITAS
    match /room_visits/{visitId} {
      // Staff y Workers ven visitas. 
      // Propietario ve SOLO visitas a SUS propiedades (Transparencia).
      allow read: if isTeam() || (isOwner() && propertyBelongsToOwner(resource.data.propertyId));
      allow create: if isTeam(); // Workers registran visitas
      allow update, delete: if isStaff(); // Solo Staff corrige/borra
    }

    // NOTICIAS INTERNAS
    match /internal_news/{newsId} {
      allow read: if isTeam();
      allow write: if isStaff();
    }

    // TRACKING DE VENTAS
    match /sales_tracker/{activityId} {
      allow read, write: if isStaff();
    }

    // BLACKLIST / INCIDENCIAS (SENSIBLE)
    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff();
    }

    // MENSAJES WEB (CONTACTO)
    match /web_messages/{msgId} {
      allow create: if true; // Cualquiera puede enviar mensaje
      allow read, update, delete: if isStaff();
    }

    // Bloqueo por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
