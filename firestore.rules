
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    // Verifica si el usuario está autenticado en Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si el usuario accede a su propio documento (por UID)
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Obtiene los datos del usuario actual de la colección 'users'
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica el rol. 
    // MEJORA: Es robusto si el campo 'active' no existe (asume true).
    function hasRole(role) {
      let user = getUserData();
      return isAuthenticated() && 
             user.role == role && 
             (!("active" in user) || user.active == true);
    }

    // STAFF: Acceso total (Staff, Admin, Owner)
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('owner');
    }

    // WORKER: Acceso operativo limitado
    function isWorker() {
      return hasRole('worker');
    }

    // STAFF O WORKER: Para funciones operativas compartidas
    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    // --- REGLAS POR COLECCIÓN ---

    // 1. USUARIOS (USERS)
    // Importante: Permitir lectura a authenticated para que getUserData() funcione en el cliente si es necesario
    match /users/{userId} {
      allow read: if isSelf(userId) || isStaffOrWorker();
      allow create: if isStaff(); // Solo staff crea usuarios
      allow update: if isStaff() || isSelf(userId); // Uno mismo puede actualizar datos básicos
      allow delete: if isStaff();
    }

    // 2. PROPIEDADES (PROPERTIES)
    // Lectura pública para la web. Escritura restringida.
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 3. OPORTUNIDADES (OPPORTUNITIES)
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 4. ENCARGOS DE COMPRA (BUYER_REQUESTS)
    match /buyer_requests/{requestId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // 5. CONTRATOS (CONTRACTS)
    match /contracts/{contractId} {
      allow read: if isStaff() 
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.tenantId == request.auth.uid);
      allow write: if isStaff();
    }

    // 6. TAREAS Y TABLEROS (TASKS & BOARDS)
    // Fundamental para el TaskManager. Permitimos lectura/escritura a Staff y Workers.
    match /tasks/{taskId} {
      allow read, write: if isStaffOrWorker();
    }
    match /task_boards/{boardId} {
      allow read, write: if isStaffOrWorker();
    }

    // 7. BUZÓN SOCIAL (SOCIAL_INBOX)
    match /social_inbox/{msgId} {
      allow read: if isStaff();
      allow create: if true; // Permitir entrada desde web (formularios públicos simulados) o Staff
      allow update, delete: if isStaff();
    }

    // 8. CONTABILIDAD (ACCOUNTING)
    match /accounting/{transactionId} {
      allow read, write: if isStaff();
    }

    // 9. SUMINISTROS (SUPPLY_RECORDS)
    match /supply_records/{recordId} {
      allow read: if isAuthenticated(); // Inquilinos pueden ver
      allow write: if isStaff();
    }

    // 10. PIPELINE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      allow read: if isStaffOrWorker();
      allow create: if isStaffOrWorker();
      allow update: if isStaff(); // Solo Staff aprueba/rechaza
      allow delete: if isStaff();
    }

    // 11. REGISTRO DE VISITAS (ROOM_VISITS)
    match /room_visits/{visitId} {
      allow read: if isStaffOrWorker();
      allow create: if isStaffOrWorker();
      allow update, delete: if isStaff();
    }

    // Bloqueo por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
