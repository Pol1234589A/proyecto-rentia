
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA (HELPERS) ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // Roles Jerárquicos
    function isStaff() {
      return hasRole('staff') || hasRole('admin') || hasRole('agency');
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isWorker() {
      return hasRole('worker');
    }

    // Helper combinado para operaciones de gestión diaria
    function isStaffOrWorker() {
      return isStaff() || isWorker();
    }

    // --- REGLAS POR COLECCIÓN ---

    // 1. USUARIOS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isStaff();
    }

    // 2. PROPIEDADES (Catálogo y Configuración)
    match /properties/{propertyId} {
      // Lectura pública para la web
      allow read: if true; 
      
      // CRÍTICO: Escritura permitida para Staff y Workers.
      // Owners pueden editar SOLO si son dueños de la propiedad (para configurar inversión)
      allow update: if isStaffOrWorker() || (isOwner() && resource.data.ownerId == request.auth.uid);
      allow create, delete: if isStaffOrWorker();
    }

    // 3. DOCUMENTOS DE PROPIEDAD
    match /property_documents/{docId} {
      allow read: if isStaff() || isOwner() || isWorker();
      allow create: if isAuthenticated();
      // MODIFICADO: Permitir al owner borrar SUS propios documentos (si se equivocó al subir)
      allow update: if isStaff();
      allow delete: if isStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 4. FACTURAS DE SUMINISTROS
    match /supply_invoices/{invoiceId} {
      allow read: if isStaff() || isOwner() || isWorker();
      allow create: if isAuthenticated(); 
      allow update, delete: if isStaff();
    }
    
    // 5. CÁLCULOS DE SUMINISTROS
    match /supply_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 6. AJUSTES ECONÓMICOS
    match /adjustments/{adjustmentId} {
      allow read: if isStaff() || (isOwner() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaff();
    }

    // 7. CONTABILIDAD
    match /accounting/{docId} {
      allow read, write: if isStaff();
    }

    // 8. OPORTUNIDADES (Venta)
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // 9. CONTRATOS
    match /contracts/{contractId} {
      // Workers necesitan leer contratos para saber quién está en la habitación si hay incidencias
      allow read: if isStaffOrWorker() || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.tenantId == request.auth.uid));
      allow write: if isStaff();
    }

    // 10. TAREAS
    match /tasks/{taskId} {
      // Gestión total de tareas compartida
      allow read, write: if isStaffOrWorker();
    }

    match /task_boards/{boardId} {
      allow read, write: if isStaffOrWorker();
    }

    // 11. PIPELINE CANDIDATOS
    match /candidate_pipeline/{candidateId} {
      // Workers pueden ver y gestionar candidatos para visitas
      allow read: if isStaffOrWorker() || (isOwner() && resource.data.ownerId == request.auth.uid);
      allow write: if isStaffOrWorker();
    }

    // 12. VISITAS
    match /room_visits/{visitId} {
      allow read, write: if isStaffOrWorker();
    }

    // 13. NOTICIAS INTERNAS
    match /internal_news/{newsId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 14. FACTURAS TRABAJADORES
    match /worker_invoices/{invoiceId} {
      allow read: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
      allow create: if isStaff() || (isWorker() && request.resource.data.workerId == request.auth.uid);
      allow update: if isStaff(); 
      allow delete: if isStaff() || (isWorker() && resource.data.workerId == request.auth.uid);
    }

    // 15. WEB FORMS (Públicos para escritura inicial)
    match /buyer_requests/{requestId} {
      allow read: if true; 
      allow create: if true;
      allow update, delete: if isStaff();
    }

    match /opportunity_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }
    
    match /pending_transfers/{transferId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    // 16. TRACKING Y SEGURIDAD
    match /sales_tracker/{trackId} {
      allow read, write: if isStaff();
    }

    match /tenant_blacklist/{entryId} {
      allow read, write: if isStaff();
    }

    // Regla por defecto de seguridad
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
